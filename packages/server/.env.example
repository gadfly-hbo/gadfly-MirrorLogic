# MirrorLogic Backend Configuration Example

# 运行端口
PORT=3001

# 跨域允许的来源 (前端地址)
# 生产环境请设置为你的 Vercel 域名，多个地址用逗号分隔
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# 数据库存储路径 (默认为项目根目录下的 data/db.json)
# 云端部署建议指向持久化挂载目录，例如 /var/lib/data/db.json
DATABASE_PATH=

# 大语言模型 API 配置
# 必填：用于策略工坊和沙盘推演
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com

# 可选：如果需要切换到 OpenAI 或其他兼容接口
# OPENAI_API_KEY=
# OPENAI_BASE_URL=
